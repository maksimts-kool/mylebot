DATABASE_URL=postgresql://session_tracker:change-me@db:5432/session_tracker?schema=public
POSTGRES_USER=session_tracker
POSTGRES_PASSWORD=change-me
POSTGRES_DB=session_tracker

DISCORD_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_GUILD_ID=

BLOXLINK_API_KEY=
BLOXLINK_BASE_URL=https://api.blox.link/v4/public

ROBLOX_INGESTION_SECRET=replace-with-at-least-32-random-characters
# Shared secret for the store-owners portal's internal endpoints: notifications
# (POST /internal/notify) and verified owner lookup (GET /internal/verified-members).
# Leave empty to disable. Must match BOT_NOTIFY_SECRET on the site.
SITE_NOTIFY_SECRET=
ROBLOX_UNIVERSE_ID=0
ROBLOX_GROUP_ID=0
ROBLOX_ALLOWED_PLACE_IDS=0
ROBLOX_MIN_RANK=1
ROBLOX_MAX_RANK=255

# Taiga board integration. Leave TAIGA_USERNAME/TAIGA_PASSWORD/TAIGA_PROJECT_SLUG
# empty to disable the whole feature (no /taiga command, no webhook route, and
# no privileged Discord message intents requested). Set all three together.
# The forums and notifications channel are configured in Discord with /taiga.
TAIGA_BASE_URL=https://api.taiga.io
TAIGA_WEB_URL=https://tree.taiga.io
TAIGA_USERNAME=
TAIGA_PASSWORD=
TAIGA_PROJECT_SLUG=
# Must match the secret key on the Taiga webhook (Project settings ->
# Integrations -> Webhooks). Empty disables POST /v1/taiga/webhook.
TAIGA_WEBHOOK_SECRET=
TAIGA_RECONCILE_SECONDS=600

API_HOST=0.0.0.0
API_PORT=3000
APP_BIND_IP=127.0.0.1
APP_PORT=3000
TRUST_PROXY=loopback
REPORT_TIMEZONE=Europe/Tallinn
RECONNECT_GRACE_SECONDS=120
HEARTBEAT_STALE_SECONDS=75
DISCORD_UPDATE_SECONDS=60
MAX_BATCH_SIZE=100
MAX_EVENT_AGE_SECONDS=300
PROCESSED_EVENT_RETENTION_DAYS=30
