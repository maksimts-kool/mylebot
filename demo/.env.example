# Demo-only environment. Copy to demo/.env and fill in to run the live Discord demo.
# Everything here is namespaced DEMO_* and never touches the production bot's config.
# The offline simulation (demo/simulate.ts) and tests need NONE of these.

# --- Discord (only needed for the live bot, `npm run demo`) ---
DEMO_DISCORD_TOKEN=
DEMO_APPLICATION_ID=
DEMO_GUILD_ID=

# --- Roblox Open Cloud (only needed to actually set group ranks) ---
# Leave the API key empty to run rank-sync in dry-run mode (logs the intended change).
# The key needs group role-management scope and the bot account must OUTRANK LS/LE/SS/ES.
DEMO_ROBLOX_GROUP_ID=0
DEMO_ROBLOX_OPEN_CLOUD_API_KEY=
DEMO_OPEN_CLOUD_BASE_URL=https://apis.roblox.com/cloud/v2

# --- Bloxlink (optional; without it the demo uses a synthetic Discord->Roblox mapping) ---
DEMO_BLOXLINK_API_KEY=
DEMO_BLOXLINK_BASE_URL=https://api.blox.link/v4/public

# --- Store & scoring ---
DEMO_STORE_PATH=demo/.data/store.json
DEMO_PASSING_SCORE=0
