generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionState {
  ACTIVE
  INACTIVE
  RECONNECTING
  ENDED
}

enum EventKind {
  JOIN
  HEARTBEAT
  LEAVE
  SHUTDOWN
}

model Identity {
  id            String    @id @default(cuid())
  robloxUserId  BigInt    @unique
  robloxUsername String
  discordUserId String?
  mappingCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]

  @@index([discordUserId])
}

model Session {
  id                    String       @id @default(cuid())
  identityId            String
  identity              Identity     @relation(fields: [identityId], references: [id])
  state                 SessionState
  startedAt             DateTime
  endedAt               DateTime?
  lastEventAt           DateTime
  lastStateAt           DateTime
  reconnectDeadline     DateTime?
  activeMilliseconds    BigInt       @default(0)
  inactiveMilliseconds  BigInt       @default(0)
  reconnectMilliseconds BigInt       @default(0)
  rankNumber            Int
  rankName              String
  universeId            BigInt
  placeId               BigInt
  jobId                 String
  deletedAt             DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  segments              TimeSegment[]
  discordMessage        DiscordMessage?
  auditEntries          AuditEntry[]

  @@index([identityId, startedAt])
  @@index([state, reconnectDeadline])
  @@index([deletedAt, startedAt])
}

model TimeSegment {
  id        String       @id @default(cuid())
  sessionId String
  session   Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  state     SessionState
  startedAt DateTime
  endedAt   DateTime?

  @@index([sessionId, startedAt])
}

model DiscordMessage {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channelId String
  messageId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RuntimeSettings {
  id              String   @id
  logsChannelId   String?
  trackingEnabled Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PermissionRole {
  roleId    String   @id
  level     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProcessedEvent {
  id          String    @id @default(cuid())
  eventId     String    @unique
  kind        EventKind
  occurredAt  DateTime
  receivedAt  DateTime  @default(now())
  sessionId   String?

  @@index([receivedAt])
}

enum TaigaCardKind {
  BUG
  SUGGESTION
}

/// A Discord forum post paired with the Taiga user story it created. Only posts
/// created after the integration was switched on ever get a row here.
model TaigaCard {
  id              String        @id @default(cuid())
  taigaStoryId    Int           @unique
  taigaRef        Int
  guildId         String
  channelId       String
  threadId        String        @unique
  kind            TaigaCardKind
  title           String
  statusName      String
  authorDiscordId String
  authorName      String
  declinedAt      DateTime?
  /// Set just before the bot deletes the story in Taiga, so the webhook the
  /// deletion triggers is not mistaken for someone declining the card.
  deleting        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([statusName])
}

/// Idempotency keys for Taiga webhook deliveries, which Taiga may retry.
model TaigaWebhookDelivery {
  id          String   @id @default(cuid())
  fingerprint String   @unique
  receivedAt  DateTime @default(now())

  @@index([receivedAt])
}

/// Last known state of each epic, so the webhook and the reconcile sweep cannot
/// both announce the same change.
model TaigaEpicState {
  taigaEpicId Int      @id
  ref         Int
  subject     String
  statusName  String?
  isClosed    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaigaSettings {
  id                       String    @id
  enabled                  Boolean   @default(false)
  bugForumChannelId        String?
  suggestionForumChannelId String?
  notificationChannelId    String?
  /// Posts created before this instant are never touched.
  activatedAt              DateTime?
  /// Set once the existing epics have been recorded without announcing them.
  epicsSeededAt            DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model AuditEntry {
  id          String   @id @default(cuid())
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id])
  actorType   String
  actorId     String
  action      String
  note        String?
  before      Json?
  after       Json?
  createdAt   DateTime @default(now())

  @@index([sessionId, createdAt])
}
